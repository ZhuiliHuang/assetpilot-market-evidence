{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assetpilot.example/schemas/market-direction.schema.json",
  "title": "Market direction detail package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_version",
    "evidence_version",
    "direction_id",
    "category_id",
    "display_name",
    "data_as_of",
    "status",
    "proxy",
    "valuation_applicable",
    "metrics",
    "series",
    "chart",
    "quality",
    "source_evidence",
    "gaps",
    "calculation"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "registry_version": {"type": "string", "minLength": 1},
    "evidence_version": {"type": "string", "minLength": 1},
    "direction_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "category_id": {"enum": ["broad_style", "industry", "hong_kong"]},
    "display_name": {"type": "string", "minLength": 1, "maxLength": 40},
    "data_as_of": {"type": "string", "format": "date"},
    "status": {"enum": ["ready", "degraded", "missing"]},
    "proxy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["definition", "code", "publisher", "currency", "calendar"],
      "properties": {
        "definition": {"type": "string", "minLength": 1, "maxLength": 300},
        "code": {"type": "string", "minLength": 1, "maxLength": 40},
        "publisher": {"type": "string", "minLength": 1, "maxLength": 120},
        "currency": {"enum": ["CNY", "HKD"]},
        "calendar": {"enum": ["XSHG_XSHE", "XHKG"]}
      }
    },
    "valuation_applicable": {"type": "boolean"},
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_percentile", "five_year_percentile", "all_history_percentile"],
      "properties": {
        "current_percentile": {"$ref": "#/$defs/percentileMetric"},
        "five_year_percentile": {"$ref": "#/$defs/percentileMetric"},
        "all_history_percentile": {"$ref": "#/$defs/percentileMetric"}
      }
    },
    "series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "unit", "start_date", "end_date", "sample_count", "points"],
      "properties": {
        "metric": {"enum": ["valuation_percentile", "price_percentile"]},
        "unit": {"const": "percentile"},
        "start_date": {"type": ["string", "null"], "format": "date"},
        "end_date": {"type": ["string", "null"], "format": "date"},
        "sample_count": {"type": "integer", "minimum": 0},
        "points": {
          "type": "array",
          "items": {"$ref": "#/$defs/seriesPoint"}
        }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference_bands", "current_point", "downsampled"],
      "properties": {
        "reference_bands": {
          "type": "array",
          "prefixItems": [{"const": 20}, {"const": 50}, {"const": 80}],
          "minItems": 3,
          "maxItems": 3
        },
        "current_point": {"$ref": "#/$defs/currentPoint"},
        "downsampled": {"type": "boolean"}
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adopted_source_id", "cross_validation", "conflicts", "attempted_source_ids", "freshness"],
      "properties": {
        "adopted_source_id": {"type": ["string", "null"], "pattern": "^[a-z0-9_]+$"},
        "cross_validation": {"enum": ["confirmed", "partial", "conflict", "unavailable"]},
        "conflicts": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 300}},
        "attempted_source_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}
        },
        "freshness": {"enum": ["fresh", "degraded", "stale"]}
      }
    },
    "source_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "role", "as_of", "url", "cross_validation", "last_attempt"],
        "properties": {
          "source_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "role": {"enum": ["adopted", "cross_check", "fallback", "attempted"]},
          "as_of": {"type": ["string", "null"], "format": "date"},
          "url": {"type": "string", "format": "uri", "pattern": "^https://"},
          "cross_validation": {"enum": ["confirmed", "partial", "conflict", "unavailable"]},
          "last_attempt": {"type": "string", "format": "date-time"}
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["start_date", "end_date", "reason", "decision_impact"],
        "properties": {
          "start_date": {"type": "string", "format": "date"},
          "end_date": {"type": "string", "format": "date"},
          "reason": {"type": "string", "minLength": 1, "maxLength": 300},
          "decision_impact": {"type": "string", "minLength": 1, "maxLength": 300}
        }
      }
    },
    "calculation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "metric_definition", "software_version", "calculated_at"],
      "properties": {
        "method": {"const": "empirical_cdf_midrank"},
        "metric_definition": {"type": "string", "minLength": 1, "maxLength": 300},
        "software_version": {"type": "string", "minLength": 1},
        "calculated_at": {"type": "string", "format": "date-time"}
      }
    }
  },
  "$defs": {
    "percentileMetric": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["value", "missing_reason"],
          "properties": {
            "value": {"type": "number", "minimum": 0, "maximum": 100},
            "missing_reason": {"type": "null"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["value", "missing_reason"],
          "properties": {
            "value": {"type": "null"},
            "missing_reason": {"type": "string", "minLength": 1, "maxLength": 300}
          }
        }
      ]
    },
    "seriesPoint": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["date", "value", "missing_reason"],
          "properties": {
            "date": {"type": "string", "format": "date"},
            "value": {"type": "number", "minimum": 0, "maximum": 100},
            "missing_reason": {"type": "null"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["date", "value", "missing_reason"],
          "properties": {
            "date": {"type": "string", "format": "date"},
            "value": {"type": "null"},
            "missing_reason": {"type": "string", "minLength": 1, "maxLength": 300}
          }
        }
      ]
    },
    "currentPoint": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["date", "value", "missing_reason"],
          "properties": {
            "date": {"type": "string", "format": "date"},
            "value": {"type": "number", "minimum": 0, "maximum": 100},
            "missing_reason": {"type": "null"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["date", "value", "missing_reason"],
          "properties": {
            "date": {"type": ["string", "null"], "format": "date"},
            "value": {"type": "null"},
            "missing_reason": {"type": "string", "minLength": 1, "maxLength": 300}
          }
        }
      ]
    }
  }
}
